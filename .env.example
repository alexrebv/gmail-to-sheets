# ============================================================
# ОБЯЗАТЕЛЬНО
# ============================================================
# ID Google Таблицы из URL: /spreadsheets/d/<ID>/edit
SPREADSHEET_ID=your_spreadsheet_id

# ============================================================
# Gmail OAuth2 (Вариант A — личный Gmail)
# ============================================================
GMAIL_CLIENT_ID=your_client_id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your_client_secret
GMAIL_REFRESH_TOKEN=your_refresh_token

# ============================================================
# Service Account (Вариант B — Google Workspace)
# ============================================================
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# GMAIL_IMPERSONATE_EMAIL=user@yourdomain.com

# ============================================================
# Все остальные настройки (токен TG, расписания, даты)
# хранятся в листе «Настройки» Google Таблицы.
# В Railway достаточно указать только SPREADSHEET_ID + Gmail credentials.
# ============================================================
